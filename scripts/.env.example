SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCHEMA=bgs
# Optional: fallback score source (legacy Google Apps Script URL)
# LEGACY_API_URL=https://script.google.com/macros/s/XXXX/exec
# Optional: override import batch size
# IMPORT_BATCH_SIZE=100
# Optional: override truncate RPC name
# IMPORT_TRUNCATE_RPC=bgs_truncate_for_sheet_import
# Optional: path to JSON with CSV URLs (copy migration-config.example.json)
# MIGRATION_CONFIG=scripts/migration-config.json
